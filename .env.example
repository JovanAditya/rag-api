# ==============================================
# RAG API CONFIGURATION
# ==============================================
# Konfigurasi untuk rag-api (FastAPI server)
# Salin file ini ke .env dan sesuaikan nilainya


# ==============================================
# SERVER CONFIGURATION
# ==============================================
HOST=0.0.0.0
PORT=5001
DEBUG=false

# ==============================================
# CORS SETTINGS
# ==============================================
# Daftar origin yang diizinkan (comma-separated)
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ==============================================
# RAG MODEL PATH
# ==============================================
RAG_MODEL_PATH=./rag-model

# ==============================================
# LLM CONFIGURATION
# ==============================================
# Opsi: gemini, openai, anthropic, openrouter, ollama, qwen, llama
LLM_PROVIDER=openrouter
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4000

# --- OpenRouter API (RECOMMENDED - banyak model gratis!) ---
# Daftar di: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Model gratis yang tersedia (pilih salah satu):
# - google/gemini-2.0-flash-exp:free      (Recommended - Gemini 2.0 Flash gratis)
# - google/gemma-2-9b-it:free             (Google Gemma 2 9B gratis)
# - meta-llama/llama-3.2-3b-instruct:free (Llama 3.2 3B gratis)
# - qwen/qwen-2.5-7b-instruct:free        (Qwen 2.5 7B gratis)
# - mistralai/mistral-7b-instruct:free    (Mistral 7B gratis)
# - microsoft/phi-3-mini-128k-instruct:free (Phi-3 Mini gratis)
# Model berbayar murah:
# - meta-llama/llama-3.1-8b-instruct      ($0.06/1M tokens - sangat murah)
# - meta-llama/llama-3.3-70b-instruct     ($0.39/1M tokens - kualitas tinggi)
# - mistralai/mixtral-8x7b-instruct       ($0.24/1M tokens)
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# --- Gemini API (jika LLM_PROVIDER=gemini) ---
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# --- OpenAI API (jika LLM_PROVIDER=openai) ---
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-3.5-turbo

# --- Anthropic API (jika LLM_PROVIDER=anthropic) ---
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-haiku-20240307

# --- Ollama / Local LLM (jika LLM_PROVIDER=ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:latest

# --- Qwen Local (jika LLM_PROVIDER=qwen) ---
QWEN_MODEL=qwen3:8b

# --- Llama Local (jika LLM_PROVIDER=llama) ---
LLAMA_MODEL=llama3.2:latest

# ==============================================
# RETRIEVAL CONFIGURATION
# ==============================================
PIPELINE_TYPE=advanced
MAX_RESULTS=5
USE_RERANKING=true
EMBEDDING_MODEL=indobenchmark/indobert-base-p2
EMBEDDING_DEVICE=cuda

# ==============================================
# DATA PATHS
# ==============================================
DATA_PATH=./data
PROCESSED_DIR=./data/processed
DOCUMENTS_DIR=./data/documents
CHROMA_DIR=./data/chroma_db
BM25_CACHE_DIR=./data/bm25_cache

# ==============================================
# API SECURITY
# ==============================================
API_SECRET_KEY=your-secret-key-here
API_RATE_LIMIT=100

# ==============================================
# DOCUMENT PROCESSING
# ==============================================
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf,docx,txt

# ==============================================
# LOGGING
# ==============================================
LOG_LEVEL=INFO
LOG_FILE=./logs/api.log
